# Production Environment Variables for Render
PORT=3001
NODE_ENV=production

# JWT Secret (generate a new one for production)
JWT_SECRET=your-production-jwt-secret-here-change-this

# Session Secret
SESSION_SECRET=your-production-session-secret-change-this

# Bot Registration Secret
BOT_REGISTER_SECRET=crimson-register-secret-2024
BOT_ADMIN_SECRET=crimson-admin-secret-2024

# Discord OAuth (get from Discord Developer Portal)
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=https://your-app-name.onrender.com/auth/discord/callback

# Discord Server Settings
DISCORD_GUILD_ID=your-discord-guild-id
ADMIN_ROLE_ID=your-admin-role-id

# Database (Render provides PostgreSQL)
DATABASE_URL=postgresql://username:password@host:port/database

# License File Path (Render uses /tmp for temporary storage)
LICENSES_FILE=/tmp/licenses.json
